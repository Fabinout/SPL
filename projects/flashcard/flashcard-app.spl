; ============================================================================
; Each routine displays the question, waits, displays answer, then loops

(label card-0)
(drop)
(print-rom-string que-1)
(push 10) (out 0x01)
(call wait-key)
(print-rom-string ans-1)
(push 10) (out 0x01)
(jump main-loop)

