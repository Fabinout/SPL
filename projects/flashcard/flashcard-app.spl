(label program-start)

; ============================================================================
; MAIN PROGRAM LOOP
; ============================================================================
;
; Flow:
; 1. Get random number (0-255)
; 2. Mod 6 to select from 6 cards
; 3. Dispatch to correct card display
; 4. Display question
; 5. Wait (delay)
; 6. Display answer
; 7. Repeat
;

(label main-loop)

; Get random card selection
(in 0x10)               ; Read RNG (0-255)
(push 24)               ; Mod 24 (for all 24 cards)
(mod)                   ; Result: 0-23
(dup)                   ; Keep copy for comparison
(store 0x0100)          ; Store card index in memory (0x0100)

; ============================================================================
; DISPATCH: Jump to correct card based on index (0-23)
; ============================================================================

(dup)
(push 1)
(sub)
(jump-if-zero card-1)

(dup)
(push 2)
(sub)
(jump-if-zero card-2)

(dup)
(push 3)
(sub)
(jump-if-zero card-3)

(dup)
(push 4)
(sub)
(jump-if-zero card-4)

(dup)
(push 5)
(sub)
(jump-if-zero card-5)

(dup)
(push 6)
(sub)
(jump-if-zero card-6)

(dup)
(push 7)
(sub)
(jump-if-zero card-7)

(dup)
(push 8)
(sub)
(jump-if-zero card-8)

(dup)
(push 9)
(sub)
(jump-if-zero card-9)

(dup)
(push 10)
(sub)
(jump-if-zero card-10)

(dup)
(push 11)
(sub)
(jump-if-zero card-11)

(dup)
(push 12)
(sub)
(jump-if-zero card-12)

(dup)
(push 13)
(sub)
(jump-if-zero card-13)

(dup)
(push 14)
(sub)
(jump-if-zero card-14)

(dup)
(push 15)
(sub)
(jump-if-zero card-15)

(dup)
(push 16)
(sub)
(jump-if-zero card-16)

(dup)
(push 17)
(sub)
(jump-if-zero card-17)

(dup)
(push 18)
(sub)
(jump-if-zero card-18)

(dup)
(push 19)
(sub)
(jump-if-zero card-19)

(dup)
(push 20)
(sub)
(jump-if-zero card-20)

(dup)
(push 21)
(sub)
(jump-if-zero card-21)

(dup)
(push 22)
(sub)
(jump-if-zero card-22)

(dup)
(push 23)
(sub)
(jump-if-zero card-23)

; Default: card 0
(jump card-0)

; ============================================================================
