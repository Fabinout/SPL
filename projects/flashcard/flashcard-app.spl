; ============================================================================
; KEYBOARD INPUT ROUTINE - Wait for user to press any key
; ============================================================================
; Polls the keyboard (KBD_STATUS port 0x21) until a key is pressed.
; Then reads the key (KBD_DATA port 0x20) to consume it from the queue.
; Finally prints a newline before returning.

(label wait-key)

(label wait-for-input)
(in 0x21)               ; Read KBD_STATUS (port 0x21)
(push 1)
(and)                   ; Extract bit0 (data ready): 1 if key available, 0 otherwise
(jump-if-zero wait-for-input)  ; If no key, loop back and wait

; Key is available, read it (consume from queue)
(in 0x20)               ; Read KBD_DATA (port 0x20) -> key code on stack
(drop)                  ; Discard the key code (we don't care which key)

; Print newline between Q and A
(push 10) (out 0x01)
(return)

; ============================================================================
; END OF PROGRAM
; Note: This is a continuous loop - it will run forever.
; All 24 European capital flashcards are now fully integrated.
; In a real app, you could add a quit condition (e.g., timer, keyboard)
; ============================================================================

(halt)
