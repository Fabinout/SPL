; ============================================================================
; MAIN EDITOR LOOP
; ============================================================================

(label editor-main)

; Welcome message
(push 10)(out 0x01)
(push 70)(out 0x01)     ; 'F'
(push 108)(out 0x01)    ; 'l'
(push 97)(out 0x01)     ; 'a'
(push 115)(out 0x01)    ; 's'
(push 104)(out 0x01)    ; 'h'
(push 99)(out 0x01)     ; 'c'
(push 97)(out 0x01)     ; 'a'
(push 114)(out 0x01)    ; 'r'
(push 100)(out 0x01)    ; 'd'
(push 32)(out 0x01)
(push 69)(out 0x01)     ; 'E'
(push 100)(out 0x01)    ; 'd'
(push 105)(out 0x01)    ; 'i'
(push 116)(out 0x01)    ; 't'
(push 111)(out 0x01)    ; 'o'
(push 114)(out 0x01)    ; 'r'
(push 10)(out 0x01)

(push 70)(out 0x01)     ; 'F'
(push 105)(out 0x01)    ; 'i'
(push 108)(out 0x01)    ; 'l'
(push 101)(out 0x01)    ; 'e'
(push 110)(out 0x01)    ; 'n'
(push 97)(out 0x01)     ; 'a'
(push 109)(out 0x01)    ; 'm'
(push 101)(out 0x01)    ; 'e'
(push 58)(out 0x01)     ; ':'
(push 32)(out 0x01)

; Read filename
(call read-filename)

; Initialize
(push 0)
(store 0x0100)          ; CARD_COUNT = 0

; Try to load file
(call load-file)

; Show loaded message
(push 10)(out 0x01)
(push 76)(out 0x01)     ; 'L'
(push 111)(out 0x01)    ; 'o'
(push 97)(out 0x01)     ; 'a'
(push 100)(out 0x01)    ; 'd'
(push 101)(out 0x01)    ; 'e'
(push 100)(out 0x01)    ; 'd'
(push 32)(out 0x01)
(load 0x0100)
(call print-num)
(push 32)(out 0x01)
(push 99)(out 0x01)     ; 'c'
(push 97)(out 0x01)     ; 'a'
(push 114)(out 0x01)    ; 'r'
(push 100)(out 0x01)    ; 'd'
(push 115)(out 0x01)    ; 's'
(push 10)(out 0x01)

(label main-menu-loop)
(call show-menu)

; Get choice
(call wait-key)
(dup)
(store 0x0101)          ; Store in TEMP_VAR

; Process choice
(push 0x41)
(sub)
(jump-if-zero choice-add)

(load 0x0101)
(push 0x4C)
(sub)
(jump-if-zero choice-list)

(load 0x0101)
(push 0x44)
(sub)
(jump-if-zero choice-delete)

(load 0x0101)
(push 0x53)
(sub)
(jump-if-zero choice-save)

(load 0x0101)
(push 0x51)
(sub)
(jump-if-zero choice-quit)

; Invalid - loop
(jump main-menu-loop)

(label choice-add)
(call do-add)
(jump main-menu-loop)

(label choice-list)
(call do-list)
(jump main-menu-loop)

(label choice-delete)
(call do-delete)
(jump main-menu-loop)

(label choice-save)
(call save-file)
(push 10)(out 0x01)
(push 80)(out 0x01)     ; 'P'
(push 114)(out 0x01)    ; 'r'
(push 101)(out 0x01)    ; 'e'
(push 115)(out 0x01)    ; 's'
(push 115)(out 0x01)    ; 's'
(push 32)(out 0x01)
(push 97)(out 0x01)     ; 'a'
(push 110)(out 0x01)    ; 'n'
(push 121)(out 0x01)    ; 'y'
(push 32)(out 0x01)
(push 107)(out 0x01)    ; 'k'
(push 101)(out 0x01)    ; 'e'
(push 121)(out 0x01)    ; 'y'
(push 32)(out 0x01)
(push 116)(out 0x01)    ; 't'
(push 111)(out 0x01)    ; 'o'
(push 32)(out 0x01)
(push 99)(out 0x01)     ; 'c'
(push 111)(out 0x01)    ; 'o'
(push 110)(out 0x01)    ; 'n'
(push 116)(out 0x01)    ; 't'
(push 105)(out 0x01)    ; 'i'
(push 110)(out 0x01)    ; 'n'
(push 117)(out 0x01)    ; 'u'
(push 101)(out 0x01)    ; 'e'
(push 46)(out 0x01)     ; '.'
(push 10)(out 0x01)
(call wait-key)
(jump main-menu-loop)

(label choice-quit)
(push 10)(out 0x01)
(push 71)(out 0x01)     ; 'G'
(push 111)(out 0x01)    ; 'o'
(push 111)(out 0x01)    ; 'o'
(push 100)(out 0x01)    ; 'd'
(push 98)(out 0x01)     ; 'b'
(push 121)(out 0x01)    ; 'y'
(push 101)(out 0x01)    ; 'e'
(push 33)(out 0x01)     ; '!'
(push 10)(out 0x01)

(halt)
