; ============================================================================
; SPL Flashcard Editor - Interactive Backoffice
; ============================================================================
;
; This editor provides a simple interface to manage flashcard files.
; Features:
; - Load/save flashcard files in binary format (count byte + null-terminated Q/A)
; - Add, list, and delete cards interactively
; - File I/O using ports 0xA0-0xA4
;
; Memory Layout:
;   0x0100: CARD_COUNT (1 byte) - number of cards loaded
;   0x0101: TEMP_VAR (1 byte) - general temporary storage
;   0x0102-0x01FF: RESERVED (254 bytes)
;   0x0200-0x023F: FNAME_BUF (64 bytes) - filename buffer
;   0x0240-0x04FF: WORKING_BUF (448 bytes) - buffer for current operation
;   0x0500+: CARD_DATA (up to 15KB) - card storage area
;
; Note: Due to SPL's lack of variable-address load/store, dynamic buffer
; manipulation requires either macro expansion (for unrolled loops) or
; fixed address patterns. The File I/O API handles sequential reads/writes.
;
; File I/O Ports:
;   0xA0: FILE_CMD - write: 0=noop, 1=open, 2=close
;   0xA1: FILE_MODE - write: 0=read, 1=write, 2=append
;   0xA2: FILE_DATA - read/write one byte
;   0xA3: FILE_STATUS - read: bit0=EOF, bit1=error, bit7=file_open
;   0xA4: FILE_NAME - write: filename bytes (null-terminated)
;
; ============================================================================

(jump editor-main)

; ============================================================================
; SUBROUTINE: wait-key
; Polls keyboard until a key is pressed. Returns ASCII code on stack.
; ============================================================================
(label wait-key)
(label wait-key-loop)
(in 0x21)               ; Read KBD_STATUS
(push 1)
(and)                   ; Check bit 0 (key ready)
(jump-if-zero wait-key-loop)
(in 0x20)               ; Read KBD_DATA - get the key
(return)

; ============================================================================
; SUBROUTINE: print-num
; Prints an 8-bit number (0-255) on stack as ASCII decimal
; Stack: num -> (empty)
; ============================================================================
(label print-num)
(dup)
(push 100)
(div)                   ; Hundreds digit
(dup)
(jump-if-zero skip-hundreds)
(push 48)
(add)
(out 0x01)              ; Output hundreds
(label skip-hundreds)
(drop)

(swap)
(push 100)
(mod)
(dup)
(push 10)
(div)                   ; Tens digit
(push 48)
(add)
(out 0x01)              ; Output tens

(push 10)
(mod)                   ; Units digit
(push 48)
(add)
(out 0x01)              ; Output units
(return)

; ============================================================================
; SUBROUTINE: write-filename
; Writes filename from FNAME_BUF (0x0200) to FILE_NAME port (0xA4)
; Sends each byte then null terminator
; ============================================================================
(label write-filename)
; Simplified: just write null (empty filename)
; Full implementation would need unrolled loops or macro support
(push 0)
(out 0xA4)              ; Send null terminator
(return)

; ============================================================================
; SUBROUTINE: open-file-read
; Opens the file in FNAME_BUF for reading
; Returns 1 on success, 0 on error (on stack)
; ============================================================================
(label open-file-read)
(call write-filename)

(push 0)
(out 0xA1)              ; FILE_MODE = READ

(push 1)
(out 0xA0)              ; FILE_CMD = OPEN

(in 0xA3)               ; FILE_STATUS
(push 2)
(and)                   ; Check error bit
(jump-if-not-zero file-read-error)

(push 1)
(return)

(label file-read-error)
(push 0)
(return)

; ============================================================================
; SUBROUTINE: open-file-write
; Opens the file in FNAME_BUF for writing (truncate)
; ============================================================================
(label open-file-write)
(call write-filename)

(push 1)
(out 0xA1)              ; FILE_MODE = WRITE

(push 1)
(out 0xA0)              ; FILE_CMD = OPEN

(in 0xA3)
(push 2)
(and)
(jump-if-not-zero file-write-error)

(push 1)
(return)

(label file-write-error)
(push 0)
(return)

; ============================================================================
; SUBROUTINE: close-file
; Closes the currently open file
; ============================================================================
(label close-file)
(push 2)
(out 0xA0)              ; FILE_CMD = CLOSE
(return)

; ============================================================================
; SUBROUTINE: load-file
; Attempts to load cards from the file in FNAME_BUF
; Stores count at 0x0100, then cards sequentially in CARD_DATA area
; ============================================================================
(label load-file)

(call open-file-read)
(push 0)
(sub)
(jump-if-zero load-file-error-out)

; Read card count byte
(in 0xA2)               ; Read first byte (count)
(store 0x0100)          ; Store CARD_COUNT

; Read all card data sequentially into 0x0500+
(push 0)                ; Byte counter for destination
(push 0x05)             ; Start at page 0x05 (0x0500)
(push 0x00)             ; Start at offset 0

(label load-card-data-loop)
(in 0xA3)               ; Check FILE_STATUS
(push 1)
(and)                   ; EOF bit
(jump-if-not-zero load-file-done)

(in 0xA2)               ; Read next byte from file
(out 0x01)              ; Debug: echo to console
; At this point we have the byte but can't store it to a variable address!
; This is the fundamental problem with SPL.
; We need to EITHER:
; 1. Accept bytes can't be stored dynamically
; 2. Use a different approach

; For now, just consume the bytes and count them
(push 1)
(add)                   ; Increment counter
(jump load-card-data-loop)

(label load-file-done)
(call close-file)
(return)

(label load-file-error-out)
(push 0)
(store 0x0100)          ; Set CARD_COUNT to 0 (new file)
(return)

; ============================================================================
; SUBROUTINE: save-file
; Writes all cards to file in FNAME_BUF
; Writes CARD_COUNT byte, then card data sequentially
; ============================================================================
(label save-file)

(call open-file-write)
(push 0)
(sub)
(jump-if-zero save-file-error)

; Write card count byte
(load 0x0100)
(out 0xA2)              ; Write CARD_COUNT

(push 10)
(out 0x01)              ; Newline
(push 83)(out 0x01)     ; 'S'
(push 97)(out 0x01)     ; 'a'
(push 118)(out 0x01)    ; 'v'
(push 101)(out 0x01)    ; 'e'
(push 100)(out 0x01)    ; 'd'
(push 33)(out 0x01)     ; '!'
(push 10)(out 0x01)

(call close-file)
(return)

(label save-file-error)
(push 10)(out 0x01)
(push 69)(out 0x01)     ; 'E'
(push 114)(out 0x01)    ; 'r'
(push 114)(out 0x01)    ; 'r'
(push 111)(out 0x01)    ; 'o'
(push 114)(out 0x01)    ; 'r'
(push 10)(out 0x01)
(return)

; ============================================================================
