; Displays the main menu
; ============================================================================
(label show-menu)
(push 10)(out 0x01)
(push 61)(out 0x01)     ; '='
(push 61)(out 0x01)
(push 61)(out 0x01)
(push 61)(out 0x01)
(push 61)(out 0x01)
(push 61)(out 0x01)
(push 61)(out 0x01)
(push 61)(out 0x01)
(push 61)(out 0x01)
(push 61)(out 0x01)
(push 32)(out 0x01)

(push 70)(out 0x01)     ; 'F'
(push 108)(out 0x01)    ; 'l'
(push 97)(out 0x01)     ; 'a'
(push 115)(out 0x01)    ; 's'
(push 104)(out 0x01)    ; 'h'
(push 99)(out 0x01)     ; 'c'
(push 97)(out 0x01)     ; 'a'
(push 114)(out 0x01)    ; 'r'
(push 100)(out 0x01)    ; 'd'
(push 32)(out 0x01)

(push 69)(out 0x01)     ; 'E'
(push 100)(out 0x01)    ; 'd'
