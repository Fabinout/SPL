(push 91)(out 0x01)     ; '['
(push 65)(out 0x01)     ; 'A'
(push 93)(out 0x01)     ; ']'
(push 32)(out 0x01)
(push 65)(out 0x01)     ; 'A'
(push 100)(out 0x01)    ; 'd'
(push 100)(out 0x01)    ; 'd'
(push 10)(out 0x01)

(push 91)(out 0x01)     ; '['
(push 76)(out 0x01)     ; 'L'
(push 93)(out 0x01)     ; ']'
(push 32)(out 0x01)
(push 76)(out 0x01)     ; 'L'
(push 105)(out 0x01)    ; 'i'
(push 115)(out 0x01)    ; 's'
(push 116)(out 0x01)    ; 't'
(push 10)(out 0x01)

(push 91)(out 0x01)     ; '['
(push 68)(out 0x01)     ; 'D'
(push 93)(out 0x01)     ; ']'
(push 32)(out 0x01)
(push 68)(out 0x01)     ; 'D'
(push 101)(out 0x01)    ; 'e'
(push 108)(out 0x01)    ; 'l'
(push 101)(out 0x01)    ; 'e'
(push 116)(out 0x01)    ; 't'
(push 101)(out 0x01)    ; 'e'
(push 10)(out 0x01)

(push 91)(out 0x01)     ; '['
(push 83)(out 0x01)     ; 'S'
(push 93)(out 0x01)     ; ']'
(push 32)(out 0x01)
(push 83)(out 0x01)     ; 'S'
(push 97)(out 0x01)     ; 'a'
(push 118)(out 0x01)    ; 'v'
(push 101)(out 0x01)    ; 'e'
(push 10)(out 0x01)

(push 91)(out 0x01)     ; '['
(push 81)(out 0x01)     ; 'Q'
(push 93)(out 0x01)     ; ']'
(push 32)(out 0x01)
(push 81)(out 0x01)     ; 'Q'
(push 117)(out 0x01)    ; 'u'
(push 105)(out 0x01)    ; 'i'
(push 116)(out 0x01)    ; 't'
(push 10)(out 0x01)
(push 10)(out 0x01)

(push 67)(out 0x01)     ; 'C'
(push 97)(out 0x01)     ; 'a'
(push 114)(out 0x01)    ; 'r'
(push 100)(out 0x01)    ; 'd'
(push 115)(out 0x01)    ; 's'
(push 58)(out 0x01)     ; ':'
(push 32)(out 0x01)
(load 0x0100)
(call print-num)
(push 10)(out 0x01)

(push 67)(out 0x01)     ; 'C'
(push 104)(out 0x01)    ; 'h'
(push 111)(out 0x01)    ; 'o'
(push 105)(out 0x01)    ; 'i'
(push 99)(out 0x01)     ; 'c'
(push 101)(out 0x01)    ; 'e'
(push 58)(out 0x01)     ; ':'
(push 32)(out 0x01)

(return)

; ============================================================================
; SUBROUTINE: read-filename
; Reads and echoes filename from keyboard
; ============================================================================
(label read-filename)
(label read-filename-loop)
(call wait-key)         ; Key on stack
(dup)                   ; Duplicate for Enter check
(push 0x0D)             ; Enter key code
(sub)
(jump-if-zero read-filename-done)

; Key is still on stack - echo it
(out 0x01)
(jump read-filename-loop)

(label read-filename-done)
(push 10)(out 0x01)     ; Newline
(return)

