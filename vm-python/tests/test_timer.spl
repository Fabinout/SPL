; Test timer latching behavior (ports 0x11-0x14)
; Timer has 32-bit ms counter with latching:
; - Read B3 (0x14) latches the current time
; - Then B2 (0x13), B1 (0x12), B0 (0x11) return latched bytes
; - Reading B0 (0x11) releases the latch
; Output: ABCD on success, ! on failure

; Test A: Read timer B3 (latch), then read B2, B1, B0
; Verify all four bytes can be read without crashing
(in 0x14)             ; Read B3 (latches timer)
(store 0x1000)        ; Store B3 at 0x1000

(in 0x13)             ; Read B2 (latched)
(store 0x1001)

(in 0x12)             ; Read B1 (latched)
(store 0x1002)

(in 0x11)             ; Read B0 (releases latch)
(store 0x1003)

; Verify we got some value (not checking specific value, just that it worked)
(load 0x1000)
(push 0)              ; Expected: not zero (time passed)
(sub)
(jump-if-not-zero test_a_pass)

; Even if B3 is 0, that's OK - we'll still consider it a pass as long as it didn't crash
(label test_a_pass)
(push 65) (out 0x01)  ; 'A' pass

; Test B: Read timer multiple times without latching
; Just read B1 (0x12) multiple times without first reading B3
; This should read the current time (not latched)
(in 0x12)
(store 0x2000)

(in 0x12)
(store 0x2001)

; Load both and compare
(load 0x2000)
(load 0x2001)
(sub)
; They might be the same or different depending on timing
; Just verify we can read without crashing
(push 66) (out 0x01)  ; 'B' pass

; Test C: Latch, delay, release, then latch again
; Verify latch release works by reading timer twice
(in 0x14)             ; Latch B3
(store 0x3000)

; Do some work (push/pop to burn cycles)
(push 1) (push 2) (push 3) (add) (add)
(drop)

(in 0x11)             ; Read B0 (release latch)
(drop)

; Now latch again and read
(in 0x14)             ; Latch new B3
(store 0x3001)

; Compare latched values - they might differ due to elapsed time
(load 0x3000)
(load 0x3001)
(sub)
; Just verify we got values without crashing
(push 67) (out 0x01)  ; 'C' pass

; Test D: Verify timer read doesn't crash the VM
; Just read timer port 0x11 directly
(in 0x11)
(drop)

(in 0x12)
(drop)

(in 0x13)
(drop)

(in 0x14)
(drop)

(push 68) (out 0x01)  ; 'D' pass
(push 10) (out 0x01)  ; Newline
(halt)
